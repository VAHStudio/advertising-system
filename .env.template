# 环境变量配置
# 复制此文件为 .env 并填写实际的 API Key 和配置

# ================================
# Kimi AI API 配置 (必须)
# 从 https://platform.moonshot.cn/ 获取
# ================================
KIMI_API_KEY=sk-your-kimi-api-key-here
KIMI_ENDPOINT=https://api.moonshot.cn/v1/chat/completions
KIMI_MODEL=kimi-k2.5
KIMI_THINKING=disabled

# ================================
# 阿里云语音交互配置 (可选)
# 如需语音输入功能，请配置
# ================================
ALIYUN_SPEECH_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SPEECH_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SPEECH_APP_KEY=your-aliyun-app-key
ALIYUN_SPEECH_ENDPOINT=wss://nls-gateway.cn-shanghai.aliyuncs.com/ws/v1

# ================================
# 数据库配置 (必须)
# ================================
DB_URL=jdbc:mysql://localhost:3306/advertising_system?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=your-database-password

# ================================
# 服务器配置 (可选，默认16000)
# ================================
SERVER_PORT=16000
SPRING_PROFILES_ACTIVE=dev
